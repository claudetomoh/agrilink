# AgriLink – Environment Configuration
# ─────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below.
# 3. NEVER commit .env — it is listed in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ── Application ───────────────────────────────────────────────────────────
APP_URL=http://localhost:8000
APP_ENV=local

# ── Mail ──────────────────────────────────────────────────────────────────
# Set ENABLE_EMAIL_DELIVERY=true only after confirming the host can send mail
ENABLE_EMAIL_DELIVERY=false
SUPPORT_EMAIL=support@agrilink.gh
MAIL_FROM_EMAIL=no-reply@localhost
